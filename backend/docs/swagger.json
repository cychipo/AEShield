{
    "swagger": "2.0",
    "info": {
        "description": "Secure file storage API with client-side encryption",
        "title": "AEShield API",
        "termsOfService": "http://localhost:6868/terms",
        "contact": {
            "name": "API Support",
            "url": "http://localhost:6868/support",
            "email": "support@aeshield.io"
        },
        "license": {
            "name": "Apache 2.0",
