PORT=6868

# JWT
JWT_SECRET=your-secret-key-change-in-production

# OAUTH - GOOGLE
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:6868/auth/google/callback

# OAUTH - GITHUB
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
