# Public ports
FRONTEND_PUBLIC_PORT=5191
BACKEND_PUBLIC_PORT=8010
MONGO_PUBLIC_PORT=27020

# Frontend build/runtime API path (same-origin via nginx proxy)
VITE_API_URL=/api/v1

# Backend runtime
PORT=8010
FRONTEND_URL=http://localhost:5191
GOOGLE_REDIRECT_URL=http://localhost:5191/api/v1/auth/google/callback
GITHUB_REDIRECT_URL=http://localhost:5191/api/v1/auth/github/callback
JWT_SECRET=change-me
MONGO_URI=mongodb://aeshield_admin:change-me@mongo:27017/aeshield?authSource=admin
MONGO_DATABASE=aeshield
FRONTEND_DIST=/app/frontend/dist

# Mongo bootstrap admin used only by reconciliation
MONGO_BOOTSTRAP_ROOT_USERNAME=root
MONGO_BOOTSTRAP_ROOT_PASSWORD=change-root-password
MONGO_ADMIN_USERNAME=aeshield_admin
MONGO_ADMIN_PASSWORD=change-me
MONGO_DEPLOYMENT_MARKER=aeshield-deployment-managed
MONGO_HOST=mongo
MONGO_PORT=27017

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
